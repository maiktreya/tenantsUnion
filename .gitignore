# =============================================================================
# Production Environment & Sensitive Credentials
# =============================================================================
.env
.wsl_env

# =============================================================================
# Nginx & Certbot (Robust Exception Rule)
# =============================================================================
# 1. Ignore absolutely everything (files & folders) inside build/nginx/
# This automatically catches 'certbot/', local 'nginx.conf', and any keys.
build/nginx/*
assets/images/*

# 2. Whitelist ONLY the initial configuration template
!build/nginx/nginx.conf.template
!assets/images/logo.png

# =============================================================================
# Python Bytecode and Caches
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# Environment and IDE Specifics
# =============================================================================
.venv/
.vscode/

# =============================================================================
# Application Storage and Generated Data
# =============================================================================
.nicegui/
storage/
screenshots/
unittest-cpp/

# =============================================================================
# Other Local Folders & Log Files
# =============================================================================
back/
dev/
logs/
ETL/tmp
doc/working-notes.md
utils/cron/tenants_sync.log
utils/cron/cron_errors.log